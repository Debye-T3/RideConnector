INTERVALS_API_KEY=replace-with-your-intervals-api-key
INTERVALS_ATHLETE_ID=0

# Default notifier is email. Set to wechat to use the retained WeChat integration.
NOTIFIER=email

EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=replace-with-smtp-user
EMAIL_SMTP_PASSWORD=replace-with-smtp-password-or-app-password
EMAIL_FROM=rideconnector@example.com
EMAIL_TO=you@example.com
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

WECHAT_APP_ID=replace-with-wechat-app-id
WECHAT_APP_SECRET=replace-with-wechat-app-secret
WECHAT_TEMPLATE_ID=replace-with-template-id
WECHAT_OPENID=replace-with-your-openid
WECHAT_TEMPLATE_FIELD_MAP={"first":"first","date":"keyword1","training":"keyword2","status":"keyword3","advice":"keyword4","nutrition":"remark"}

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-openai-compatible-api-key
OPENAI_MODEL=gpt-4.1-mini
ATHLETE_PROFILE=paste-your-long-term-athlete-profile-here
FEEDBACK_FORM_URL=

# Optional daily check-in. Leave blank for scheduled runs if you do not want manual input.
DAILY_BEDTIME=
DAILY_FATIGUE=
DAILY_SORENESS=
DAILY_RESEARCH_PRESSURE=
DAILY_CHECKIN_NOTES=

TZ=Asia/Shanghai
WEIGHT_LOSS_MODE=true
DATABASE_PATH=data/ride_connector.sqlite3
LOG_LEVEL=INFO
